# Migration Atlas — environment variables
# Copy this file to .env and fill in your values. Never commit .env.

# ---- API keys ----
# Optional. Used by the RAG model and the NLP query layer for synthesis.
ANTHROPIC_API_KEY=

# Optional. Used for experiment tracking. Leave blank to log to stdout only.
WANDB_API_KEY=
WANDB_PROJECT=migration-atlas
WANDB_ENTITY=

# ---- Graph backend ----
# 'networkx' (default, in-memory) or 'neo4j'
GRAPH_BACKEND=networkx
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=atlasdev

# ---- App ----
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Model paths ----
# Optional: override default checkpoint locations
STANCE_MODEL_PATH=checkpoints/stance-distilbert
RAG_INDEX_PATH=chroma_db/
FORECAST_MODEL_PATH=checkpoints/forecaster
EMBEDDINGS_PATH=checkpoints/node2vec.kv
